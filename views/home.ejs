<%- include('partials/header') %>

    <%- include('partials/navbar') %>

        <div class="container">

            <main class="content">
                <h2>Recipe Sharing Website</h2>

                <form action="/" method="GET" class="search-form">
                    <% if (typeof selectedCategory !== 'undefined' && selectedCategory) { %>
                        <input type="hidden" name="category" value="<%= selectedCategory %>">
                    <% } %>
                    <input type="text" name="search" placeholder="Tìm kiếm công thức món ăn..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                    <button type="submit">Tìm kiếm</button>
                    <% if ((typeof search !== 'undefined' && search) || (typeof selectedCategory !== 'undefined' && selectedCategory)) { %>
                        <a href="/" class="btn-clear-search">Xóa bộ lọc</a>
                    <% } %>
                </form>

                <div class="recipe-grid">
                    <% if (recipes && recipes.length> 0) { %>
                        <% recipes.forEach(recipe=> { %>
                            <div class="recipe-card">
                                <% if (recipe.image_url) { %>
                                    <img src="<%= recipe.image_url %>" alt="<%= recipe.title %>" class="recipe-image">
                                <% } %>
                                <div class="recipe-info">
                                    <h3>
                                        <a href="/recipes/<%= recipe.id %>">
                                            <%= recipe.title %>
                                        </a>
                                    </h3>
                                    <p class="recipe-desc">
                                        <%= recipe.description %>
                                    </p>
                                    <div class="recipe-meta">
                                        <span class="recipe-time">Thời gian: <%= (recipe.prep_time || 0) + (recipe.cook_time || 0) %> phút</span>
                                        <span class="recipe-stars">
                                            <% const stars = Math.round(recipe.avg_rating || 0); %>
                                            <% for(let i = 1; i <= 5; i++) { %>
                                                <%= i <= stars ? '★' : '☆' %>
                                            <% } %>
                                            <% if (recipe.total_ratings > 0) { %>
                                                (<%= recipe.total_ratings %>)
                                            <% } %>
                                        </span>
                                        <span class="recipe-domain"><%= recipe.category_name || 'Khác' %> - <%= recipe.author_name || 'Ẩn danh' %></span>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <p class="no-recipes">Chưa có công thức món ăn nào được chia sẻ.</p>
                                    <% } %>
                </div>

            </main>

            <%- include('partials/sidebar') %>

        </div>

        <%- include('partials/footer') %>