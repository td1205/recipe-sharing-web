<%- include('../partials/header') %><%- include('../partials/navbar') %><div class="container">    <main class="content">        <div class="admin-header flex-between">            <h2>Quản lý danh mục</h2>            <a href="/admin/categories/create" class="btn-submit">                + Thêm danh mục            </a>        </div>        <table class="admin-table">            <thead>                <tr>                    <th>ID</th>                    <th>Tên danh mục</th>                    <th>Mô tả</th>                    <th>Thao tác</th>                </tr>            </thead>            <tbody>                <% categories.forEach(category=> { %>                    <tr>                        <td><%= category.id %></td>                        <td><strong><%= category.name %></strong></td>                        <td><%= category.description || 'Chưa có mô tả' %></td>                        <td>                            <div class="action-group">                                <a href="/admin/categories/edit/<%= category.id %>" class="btn-action-edit small-btn">                                    Sửa                                </a>                                <form action="/admin/categories/delete/<%= category.id %>" method="POST" class="inline-form" onsubmit="return confirm('Bạn có chắc muốn xóa danh mục này?');">                                    <button type="submit" class="btn-action-delete" >                                        Xóa                                    </button>                                </form>                            </div>                        </td>                    </tr>                <% }) %>            </tbody>        </table>    </main>    <% const activeTab = 'categories'; %>    <%- include('../partials/admin-sidebar', { activeTab }) %></div><%- include('../partials/footer') %>