<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
  </head>
  <body>
    <div class="admin-container">
      <div class="admin-header">
        <h1>Dashboard</h1>
        <p>Xin chào Admin</p>
      </div>
      <div class="stats-grid">
        <div class="stat-card">
          <h3>Người dùng</h3>
          <div class="number"><%= stats.users %></div>
        </div>

        <div class="stat-card">
          <h3>Công thức</h3>
          <div class="number"><%= stats.recipes %></div>
        </div>

        <div class="stat-card">
          <h3>Danh mục</h3>
          <div class="number"><%= stats.categories %></div>
        </div>

        <div class="stat-card">
          <h3>Bình luận</h3>
          <div class="number"><%= stats.comments %></div>
        </div>
      </div>
    </div>
  </body>
</html>
