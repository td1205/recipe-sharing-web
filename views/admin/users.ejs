<%- include('../partials/header') %><%- include('../partials/navbar') %><div class="container">
  <main class="content">
    <div class="admin-header">
      <h2>Quản lý người dùng</h2>
    </div>
    <table class="admin-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Tên đăng nhập</th>
          <th>Email</th>
          <th>Họ và tên</th>
          <th>Vai trò</th>
          <th>Thao tác</th>
        </tr>
      </thead>
      <tbody> <% users.forEach(function(u) { %> <tr>
          <td><%= u.id %></td>
          <td><strong><%= u.username %></strong></td>
          <td><%= u.email %></td>
          <td><%= u.fullname %></td>
          <td><span class="capitalize"><%= u.role %></span></td>
          <td> <% if(u.role !== 'admin') { %>
            <a href="/admin/users/edit/<%= u.id %>" class="btn-action-edit">Sửa</a>
            <form action="/admin/users/delete/<%= u.id %>" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn xóa người dùng này?');" class="form-delete-user">
              <button type="submit" class="btn-action-delete">Xóa User</button>
            </form>
            <% } else { %>
            <a href="/admin/users/edit/<%= u.id %>" class="btn-action-edit">Sửa</a>
            <span class="text-muted-italic span-no-delete">Không thể xóa</span>
            <% } %>
          </td>
        </tr> <% }) %> </tbody>
    </table>
  </main> <% const activeTab = 'users'; %> <%- include('../partials/admin-sidebar', { activeTab }) %>
</div><%- include('../partials/footer') %>