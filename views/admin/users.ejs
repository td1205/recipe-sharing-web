<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container">
    <main class="content">
        <div class="admin-header" style="margin-bottom: 25px;">
            <h2>Quản lý người dùng</h2>
        </div>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tên đăng nhập</th>
                    <th>Email</th>
                    <th>Họ và tên</th>
                    <th>Vai trò</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(function(u) { %>
                    <tr>
                        <td><%= u.id %></td>
                        <td><strong><%= u.username %></strong></td>
                        <td><%= u.email %></td>
                        <td><%= u.fullname %></td>
                        <td><span style="text-transform: capitalize;"><%= u.role %></span></td>
                        <td>
                            <% if(u.role !== 'admin') { %>
                                <form action="/admin/users/delete/<%= u.id %>" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn xóa người dùng này?');">
                                    <button type="submit" class="btn-action-delete" style="padding: 6px 12px; font-size: 12px;">Xóa User</button>
                                </form>
                            <% } else { %>
                                <span style="color: #94a3b8; font-size: 12px; font-style: italic;">Không thể xóa</span>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </main>

    <% const activeTab = 'users'; %>
    <%- include('../partials/admin-sidebar', { activeTab }) %>
</div>

<%- include('../partials/footer') %>