<header>

    <div class="navbar">

        <h2>🍲 Recipe Sharing</h2>

        <nav>

            <a href="/">Trang chủ</a>

            <% if (typeof user !== 'undefined' && user) { %>
                <% if (user.role === 'admin') { %>
                    <a href="/admin/dashboard" style="color: #F28944; font-weight: 600;">Trang Quản trị</a>
                <% } %>
                <a href="/recipes/create">Đăng công thức</a>
                <a href="/profile">Chào, <%= user.username %>!</a>
                <a href="/logout">Đăng xuất</a>
            <% } else { %>
                <a href="/login">Đăng nhập</a>
                <a href="/register">Đăng ký</a>
            <% } %>

        </nav>

    </div>

</header>