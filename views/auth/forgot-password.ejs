<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quên mật khẩu</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page">
    <div class="auth-container">
        <h1>Quên mật khẩu</h1>
        <% if(typeof error !== "undefined"){ %>
            <div class="error-msg">
                <%= error %>
            </div>
        <%} %>
        <% if(typeof success !== "undefined"){ %>
            <div class="success-msg">
                <%= success %>
            </div>
        <% } %>
        <form action="/forgot-password" method="POST">
            <div class="form-group">
                <label>Email đăng ký</label>
                <input type="email" name="email" placeholder="Nhập email của bạn..." required>
            </div>
            <div class="form-group">
                <label>Mật khẩu mới</label>
                <input 
                    type="password" 
                    name="password" 
                    placeholder="Nhập mật khẩu mới..." 
                    pattern="(?=.*\d)(?=.*[a-zA-Z])(?=.*[!@#$%^&*(),.?&quot;:{}|<>]).{8,}"
                    title="Mật khẩu phải dài ít nhất 8 ký tự, bao gồm ít nhất 1 chữ cái, 1 chữ số và 1 ký tự đặc biệt"
                    required
                >
                <span class="input-hint">Mật khẩu phải từ 8 ký tự trở lên, gồm chữ cái, chữ số và ký tự đặc biệt (ví dụ: @, #, $, %...)</span>
            </div>
            <div class="form-group">
                <label>Xác nhận mật khẩu mới</label>
                <input type="password" name="confirm_password" placeholder="Nhập lại mật khẩu mới..." required>
            </div>
            <button type="submit" class="btn-auth">Đổi mật khẩu</button>
        </form>
        <div class="auth-footer">
            <p>Chưa có tài khoản? <a href="/register" class="auth-link">Đăng ký ngay</a></p>
            <p>Nhớ mật khẩu rồi? <a href="/login" class="auth-link">Đăng nhập</a></p>
        </div>
    </div>
</body>
</html>
