<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page">
    <div class="auth-container">
        <h1>Đăng ký</h1>
        <% if (typeof error !== "undefined"){ %>
            <div class="error-msg">
                <%= error %>
            </div>
        <%}%>
        <% if (typeof success !== "undefined") { %>
            <div class="success-msg">
                <%= success %>
            </div>
        <%}%>
        <form action="/register" method="POST">
            <div class="form-group">
                <label>Tên đăng nhập</label>
                <input type="text" name="username" placeholder="Nhập tên đăng nhập..." required />
            </div>
            <div class="form-group">
                <label>Họ và tên</label>
                <input type="text" name="fullname" placeholder="Nhập họ và tên..." required />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="Nhập email..." required />
            </div>
            <div class="form-group">
                <label>Mật khẩu</label>
                <input 
                    type="password" 
                    name="password" 
                    placeholder="Nhập mật khẩu..." 
                    pattern="(?=.*\d)(?=.*[a-zA-Z])(?=.*[!@#$%^&*(),.?&quot;:{}|<>]).{8,}"
                    title="Mật khẩu phải dài ít nhất 8 ký tự, bao gồm ít nhất 1 chữ cái, 1 chữ số và 1 ký tự đặc biệt"
                    required 
                />
                <span class="input-hint">Mật khẩu phải từ 8 ký tự trở lên, gồm chữ cái, chữ số và ký tự đặc biệt (ví dụ: @, #, $, %...)</span>
            </div>
            <div class="form-group">
                <label>Xác nhận mật khẩu</label>
                <input type="password" name="confirm_password" placeholder="Xác nhận mật khẩu..." required />
            </div>
            <button type="submit" name="register" class="btn-auth">Đăng ký</button>
        </form>
        <div class="auth-footer">
            <p>Đã có tài khoản? <a href="/login" class="auth-link">Đăng nhập</a></p>
        </div>
    </div>
</body>
</html>