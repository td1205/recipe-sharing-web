<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập</title>
</head>

<body>
    <div class="container">
        <h1>Đăng nhập</h1>
        <% if(typeof error !== "undefined"){ %>
            <div class="error">
                <%= error %>
            </div>
        <%} %>
        <% if(typeof success !== "undefined"){ %>
            <div class="success">
                <%= success %>
            </div>
        <% } %>
        <form action="/login" method="POST">
            <div class="form-group"><label>Tên đăng nhập</label>
            <input type="text" name="username" placeholder="" required></div>
            <div class="form-group"><label>Mật khẩu</label>
            <input type="password" name="password" placeholder="" required></div>
            <button type="submit">Đăng nhập</button>
        <div class="footer">
            <a href="/forgot-password">Quên mật khẩu?</a>
            <p>Chưa có tài khoản?<a href="/register">Đăng kí</a></p>
        </form>
        </div>
    </div>
</body>

</html>