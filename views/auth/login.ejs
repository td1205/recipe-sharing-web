<!DOCTYPE html><html lang="en"><head>    <meta charset="UTF-8">    <meta name="viewport" content="width=device-width, initial-scale=1.0">    <title>Đăng nhập</title>    <link rel="stylesheet" href="/css/style.css"></head><body class="auth-page">    <div class="auth-container">        <h1>Đăng nhập</h1>        <% if(typeof error !== "undefined"){ %>            <div class="error-msg">                <%= error %>            </div>        <%} %>        <% if(typeof success !== "undefined"){ %>            <div class="success-msg">                <%= success %>            </div>        <% } %>        <form action="/login" method="POST">            <div class="form-group">                <label>Tên đăng nhập</label>                <input type="text" name="username" placeholder="Nhập tên đăng nhập..." required>            </div>            <div class="form-group">                <label>Mật khẩu</label>                <input type="password" name="password" placeholder="Nhập mật khẩu..." required>            </div>            <button type="submit" class="btn-auth">Đăng nhập</button>        </form>        <div class="auth-footer">            <a href="/forgot-password" class="auth-link">Quên mật khẩu?</a>            <p>Chưa có tài khoản? <a href="/register" class="auth-link">Đăng ký</a></p>        </div>    </div></body></html>