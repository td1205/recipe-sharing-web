<%- include('../partials/header') %>    <%- include('../partials/navbar') %>        <div class="container">            <main class="content">                <a href="/" class="btn-back">← Quay lại trang chủ</a>                <div class="recipe-detail-header">                    <h2>                        <%= recipe.title %>                    </h2>                    <div class="recipe-meta-detail">                        <span>Danh mục: <strong>                                <%= recipe.category_name || 'Khác' %>                            </strong></span>                        <span>Người đăng: <strong>                                <%= recipe.author_name || 'Ẩn danh' %>                            </strong></span>                        <span>Ngày đăng: <%= new Date(recipe.created_at).toLocaleDateString('vi-VN') %></span>                    </div>                    <% if (typeof user !=='undefined' && user && (user.id===recipe.user_id || user.role==='admin' )) {                        %>                        <div class="recipe-actions">                            <a href="/recipes/edit/<%= recipe.id %>" class="btn-action-edit">Sửa công thức</a>                            <form action="/recipes/delete/<%= recipe.id %>" method="POST" class="inline-form"                                onsubmit="return confirm('Bạn có chắc chắn muốn xóa công thức này?');">                                <button type="submit" class="btn-action-delete">Xóa công thức</button>                            </form>                        </div>                        <% } %>                </div>                <% if (recipe.image_url) { %>                    <img src="<%= recipe.image_url %>" alt="<%= recipe.title %>" class="recipe-detail-image">                    <% } %>                        <div class="recipe-summary">                            <p>                                <%= recipe.description %>                            </p>                            <div class="recipe-specs">                                <div class="spec-item">                                    <span>Chuẩn bị:</span>                                    <strong>                                        <%= recipe.prep_time %> phút                                    </strong>                                </div>                                <div class="spec-item">                                    <span>Chế biến:</span>                                    <strong>                                        <%= recipe.cook_time %> phút                                    </strong>                                </div>                                <div class="spec-item">                                    <span>Khẩu phần:</span>                                    <strong>                                        <%= recipe.servings %> người                                    </strong>                                </div>                            </div>                        </div>                        <div class="recipe-section">                            <h3>Đánh giá</h3>                            <p>                                ⭐ <%= rating.averageRating ? Number(rating.averageRating).toFixed(1) : "Chưa có" %>                                    / 5                                    (<%= rating.totalRatings %> lượt đánh giá)                            </p>                            <% if (typeof user !== 'undefined' && user) { %>                                <form action="/recipes/<%= recipe.id %>/favorite" method="POST" class="mb-15">                                    <button type="submit" class="btn-favorite <%= (typeof isFav !== 'undefined' && isFav) ? 'is-fav' : 'not-fav' %>">                                        <%= (typeof isFav !== 'undefined' && isFav) ?  "Bỏ thích công thức" : "Thích công thức" %>                                    </button>                                </form>                                <form action="/recipes/<%= recipe.id %>/rate" method="POST" class="rating-form">                                    <select name="star_count" required>1                                        <option value="">Chọn số sao</option>                                        <option value="1">1 ⭐</option>                                        <option value="2">2 ⭐⭐</option>                                        <option value="3">3 ⭐⭐⭐</option>                                        <option value="4">4 ⭐⭐⭐⭐</option>                                        <option value="5">5 ⭐⭐⭐⭐⭐</option>                                    </select>                                    <button type="submit" class="btn-rate">Gửi đánh giá</button>                                </form>                            <% } else { %>                                <p class="login-prompt"><a href="/login">Đăng nhập</a> để gửi đánh giá hoặc thích món ăn.</p>                            <% } %>                        </div>                        <div class="recipe-section">                            <h3>Nguyên liệu cần chuẩn bị</h3>                            <ul class="ingredient-list">                                <% if (ingredients && ingredients.length> 0) { %>                                    <% ingredients.forEach(ing=> { %>                                        <li>                                            <%= ing.name %> - <%= ing.amount %>                                                    <%= ing.unit %>                                        </li>                                        <% }) %>                                            <% } else { %>                                                <li>Không có thông tin nguyên liệu.</li>                                                <% } %>                            </ul>                        </div>                        <div class="recipe-section">                            <h3>Các bước thực hiện</h3>                            <ol class="step-list">                                <% if (steps && steps.length> 0) { %>                                    <% steps.forEach(step=> { %>                                        <li>                                            <strong>Bước <%= step.step_number %>:</strong>                                            <p>                                                <%= step.instruction %>                                            </p>                                        </li>                                        <% }) %>                                            <% } else { %>                                                <li>Không có thông tin các bước thực hiện.</li>                                                <% } %>                            </ol>                        </div>                        <div class="recipe-section">                            <h3>Bình luận</h3>                            <% if (comments && comments.length> 0) { %>                                <% comments.forEach(comment=> { %>                                    <div class="comment-item">                                        <strong>                                            <%= comment.username %>                                        </strong>                                        <small>                                            <%= new Date(comment.created_at).toLocaleString("vi-VN") %>                                        </small>                                        <p>                                            <%= comment.content %>                                        </p>                                    </div>                                    <% }) %>                                        <% } else { %>                                            <p>Chưa có bình luận nào.</p>                                            <% } %>                                                <% if (typeof user !== 'undefined' && user) { %>                                                    <form action="/recipes/<%= recipe.id %>/comments" method="POST" class="comment-form">                                                        <textarea name="content" rows="3" placeholder="Chia sẻ ý kiến của bạn về món ăn này..." required></textarea>                                                        <button type="submit" class="btn-comment">Gửi bình luận</button>                                                    </form>                                                <% } else { %>                                                    <p class="login-prompt"><a href="/login">Đăng nhập</a> để viết bình luận.</p>                                                <% } %>                        </div>            </main>            <%- include('../partials/sidebar') %>        </div>        <%- include('../partials/footer') %>