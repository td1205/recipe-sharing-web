<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container">
            <main class="content">
                <a href="/" class="btn-back">← Quay lại trang chủ</a>

                <div class="recipe-detail-header">
                    <h2>
                        <%= recipe.title %>
                    </h2>
                    <div class="recipe-meta-detail">
                        <span>Danh mục: <strong>
                                <%= recipe.category_name || 'Khác' %>
                            </strong></span>
                        <span>Người đăng: <strong>
                                <%= recipe.author_name || 'Ẩn danh' %>
                            </strong></span>
                        <span>Ngày đăng: <%= new Date(recipe.created_at).toLocaleDateString('vi-VN') %></span>
                    </div>
                </div>

                <% if (recipe.image_url) { %>
                    <img src="<%= recipe.image_url %>" alt="<%= recipe.title %>" class="recipe-detail-image">
                    <% } %>

                        <div class="recipe-summary">
                            <p>
                                <%= recipe.description %>
                            </p>
                            <div class="recipe-specs">
                                <div class="spec-item">
                                    <span>Chuẩn bị:</span>
                                    <strong>
                                        <%= recipe.prep_time %> phút
                                    </strong>
                                </div>
                                <div class="spec-item">
                                    <span>Chế biến:</span>
                                    <strong>
                                        <%= recipe.cook_time %> phút
                                    </strong>
                                </div>
                                <div class="spec-item">
                                    <span>Khẩu phần:</span>
                                    <strong>
                                        <%= recipe.servings %> người
                                    </strong>
                                </div>
                            </div>
                        </div>

                        <div class="recipe-section">
                            <h3>Nguyên liệu cần chuẩn bị</h3>
                            <ul class="ingredient-list">
                                <% if (ingredients && ingredients.length> 0) { %>
                                    <% ingredients.forEach(ing=> { %>
                                        <li>
                                            <%= ing.name %> - <%= ing.amount %>
                                                    <%= ing.unit %>
                                        </li>
                                        <% }) %>
                                            <% } else { %>
                                                <li>Không có thông tin nguyên liệu.</li>
                                                <% } %>
                            </ul>
                        </div>

                        <div class="recipe-section">
                            <h3>Các bước thực hiện</h3>
                            <ol class="step-list">
                                <% if (steps && steps.length> 0) { %>
                                    <% steps.forEach(step=> { %>
                                        <li>
                                            <strong>Bước <%= step.step_number %>:</strong>
                                            <p>
                                                <%= step.instruction %>
                                            </p>
                                        </li>
                                        <% }) %>
                                            <% } else { %>
                                                <li>Không có thông tin các bước thực hiện.</li>
                                                <% } %>
                            </ol>
                        </div>
            </main>

            <%- include('../partials/sidebar') %>
        </div>

        <%- include('../partials/footer') %>